# ===========================================
# Mind Companion - Environment Variables
# ===========================================
# Copy this file to .env and fill your values

# Choose your LLM provider: groq | openai | ollama
LLM_PROVIDER=groq

# --- Groq (FREE - Recommended for testing) ---
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# --- OpenAI (Paid) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# --- Ollama (Completely Local & Free) ---
# Install from https://ollama.com
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mindcompanion

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Auth
SECRET_KEY=super-secret-key-change-this-in-production
